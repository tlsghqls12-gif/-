rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: prices
    // Fields: name (string), unit (string), price (string), trend (string), order (number), updatedAt (timestamp)
    //
    // Collection: items
    // Fields: title (string), content (string), category (string), imageUrl (string), createdAt (timestamp), authorUid (string)
    //
    // Collection: users
    // Fields: email (string), role (string)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "tlsghqls12@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidPrice(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.unit is string && data.unit.size() > 0 && data.unit.size() < 20 &&
             data.price is string && data.price.size() > 0 && data.price.size() < 50 &&
             data.trend in ['up', 'down', 'stable'] &&
             data.order is number;
    }

    function isValidItem(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50 &&
             data.authorUid == request.auth.uid;
    }

    function isValidInquiry(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() < 50 &&
             data.itemName is string && data.itemName.size() > 0 && data.itemName.size() < 200 &&
             data.weight is string && data.weight.size() > 0 && data.weight.size() < 100;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /prices/{priceId} {
      allow read: if true;
      allow write: if isAdmin() && isValidPrice(request.resource.data);
    }

    match /items/{itemId} {
      allow read: if true;
      allow write: if isAdmin() && isValidItem(request.resource.data);
    }

    match /inquiries/{inquiryId} {
      allow create: if isValidInquiry(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    match /purchase_status/{statusId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
